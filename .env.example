# =============================================================================
# Host UID / GID
# -----------------------------------------------------------------------------
# These are filled in by ./scripts/setup.sh based on your actual user
# (id -u / id -g). The defaults below are placeholders — they may be
# wrong for your machine, especially on macOS.
#
# Typical values:
#   - Linux: HOST_UID=1000  HOST_GID=1000
#   - macOS: HOST_UID=501   HOST_GID=20    (default user, staff group)
#
# Note: we intentionally avoid using `UID` / `GID` as variable names because
# `UID` is a read-only special variable in bash and can cause subtle errors
# in any shell scripts that try to source this file.
# =============================================================================
HOST_UID=1000
HOST_GID=1000

# Used by hermes-* container entrypoints to chown files to your user.
WANTED_UID=1000
WANTED_GID=1000

# =============================================================================
# Hermes Web UI
# =============================================================================
HERMES_WEBUI_HOST=0.0.0.0
HERMES_WEBUI_PORT=8787

# Change this before exposing via Tailscale or LAN.
HERMES_WEBUI_PASSWORD=change-me-strong-password

HERMES_WEBUI_STATE_DIR=/home/hermeswebui/.hermes/webui
HERMES_WEBUI_DEFAULT_WORKSPACE=/workspace

# =============================================================================
# Web search stack (SearXNG)
# =============================================================================
# Required by the searxng service in docker-compose.yml.
# scripts/setup.sh generates 64 hex chars automatically. If you set it
# manually, use at least 32 random characters.
# SEARXNG_SECRET_KEY=
