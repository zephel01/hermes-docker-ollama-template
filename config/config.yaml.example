model:
  provider: custom
  default: "gemma4:e4b"
  base_url: "http://host.docker.internal:11434/v1"
  api_key: ""

fallback_providers: []

model_catalog:
  enabled: false

toolsets:
  - hermes-cli

agent:
  max_turns: 90
  gateway_timeout: 1800
  api_max_retries: 3

browser:
  use_gateway: false

terminal:
  backend: local
  cwd: .
  timeout: 180

display:
  language: ja
  streaming: false

memory:
  memory_enabled: true
  user_profile_enabled: true

approvals:
  mode: manual

logging:
  level: INFO

# ---------------------------------------------------------------------------
# Web search — routes Hermes' built-in web_search tool through the SearXNG
# container started by docker-compose.yml. Also requires SEARXNG_URL=
# http://searxng:8080 in ~/.hermes/.env (NOT in docker-compose.yml's
# environment block — Hermes reads it via dotenv). `scripts/setup.sh`
# configures both for you.
# ---------------------------------------------------------------------------
web:
  search_backend: "searxng"
  # extract_backend: "firecrawl"   # add if you also want web_extract

