model:
  provider: custom
  default: "gemma4:e4b"
  base_url: "http://host.docker.internal:11434/v1"
  api_key: ""

fallback_providers: []

model_catalog:
  enabled: false

toolsets:
  - hermes-cli

agent:
  max_turns: 90
  gateway_timeout: 1800
  api_max_retries: 3

browser:
  use_gateway: false

terminal:
  backend: local
  cwd: .
  timeout: 180

display:
  language: ja
  streaming: false

memory:
  memory_enabled: true
  user_profile_enabled: true

approvals:
  mode: manual

logging:
  level: INFO
