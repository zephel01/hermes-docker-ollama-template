# Hermes MCP configuration example.
# Copy to ~/.hermes/mcp.yaml and adjust as needed.
#
# WARNING: paths inside this file MUST be valid INSIDE the hermes-agent
# container, not on your host. Do NOT paste host paths like /home/USER/...
#
# This example wires up:
#   - SearXNG     : meta-search via http://searxng:8080
#   - Crawl4AI    : page extraction via http://crawl4ai:11235
#
# Both rely on `compose.search.yml` being active so that the `searxng` and
# `crawl4ai` hostnames resolve inside the docker network.
#
# References (third-party MCP servers):
#   - https://github.com/ihor-sokoliuk/mcp-searxng        (npm: mcp-searxng)
#   - https://github.com/coleam00/mcp-crawl4ai-rag        (uvx: mcp-crawl4ai)
#
# These are community projects and their interfaces may change. Treat the
# config below as a starting point; verify with their current README.

mcp:
  servers:
    # ----------------------------------------------------------------------
    # SearXNG — meta-search.
    # The MCP server simply proxies queries to your SearXNG instance.
    # ----------------------------------------------------------------------
    searxng:
      command: "npx"
      args:
        - "-y"
        - "mcp-searxng"
      env:
        SEARXNG_URL: "http://searxng:8080"

    # ----------------------------------------------------------------------
    # Crawl4AI — fetches a page and returns clean markdown.
    # ----------------------------------------------------------------------
    crawl4ai:
      command: "uvx"
      args:
        - "mcp-crawl4ai"
      env:
        CRAWL4AI_URL: "http://crawl4ai:11235"
